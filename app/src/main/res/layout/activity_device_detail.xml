<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/thingalert_background"
  android:orientation="vertical">

  <com.google.android.material.appbar.MaterialToolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/thingalert_surface"
    android:elevation="0dp"
    android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
    app:navigationIconTint="@color/thingalert_secondary"
    app:titleTextColor="@color/thingalert_on_surface"
    android:title="@string/device_details" />

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="@color/thingalert_stroke_soft" />

  <ScrollView
    android:id="@+id/detailScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/thingalert_background"
    android:fillViewport="true">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:padding="16dp">

      <TextView
        android:id="@+id/detailName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.04"
        android:textColor="@color/thingalert_secondary"
        android:textStyle="bold"
        android:textSize="20sp" />

      <TextView
        android:id="@+id/detailIdentity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/thingalert_on_background"
        android:visibility="gone" />

      <TextView
        android:id="@+id/detailSharedOrigin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/thingalert_primary"
        android:visibility="gone" />

      <TextView
        android:id="@+id/detailKey"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/thingalert_on_background" />

      <TextView
        android:id="@+id/detailFirstSeen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/thingalert_on_background" />

      <TextView
        android:id="@+id/detailLastSeen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/thingalert_on_background" />

      <TextView
        android:id="@+id/detailStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/thingalert_on_background" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/active_ble_query"
        android:textColor="@color/thingalert_secondary"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/queryDeviceInfoNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/thingalert_on_background" />

      <com.google.android.material.button.MaterialButton
        android:id="@+id/queryDeviceInfoButton"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/query_device_info" />

      <TextView
        android:id="@+id/queryDeviceInfoStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/thingalert_on_background"
        android:visibility="gone" />

      <TextView
        android:id="@+id/detailEnrichment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/panel_surface_subtle"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:textColor="@color/thingalert_on_surface"
        android:textIsSelectable="true" />

      <TextView
        android:id="@+id/detailMetadata"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/panel_surface_subtle"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:textColor="@color/thingalert_on_surface"
        android:textIsSelectable="true" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/sightings"
        android:textColor="@color/thingalert_secondary"
        android:textStyle="bold" />

      <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sightingsList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false"
        android:paddingBottom="16dp" />
    </LinearLayout>
  </ScrollView>
</LinearLayout>
