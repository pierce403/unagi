<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginHorizontal="16dp"
  android:layout_marginTop="8dp"
  android:layout_marginBottom="8dp"
  android:clickable="true"
  android:foreground="?attr/selectableItemBackground"
  app:cardBackgroundColor="@color/thingalert_surface_variant"
  app:cardCornerRadius="20dp"
  app:cardElevation="0dp"
  app:cardUseCompatPadding="false"
  app:rippleColor="@color/thingalert_secondary"
  app:strokeColor="@color/thingalert_stroke_soft"
  app:strokeWidth="1dp">

  <LinearLayout
    android:id="@+id/deviceContent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/deviceName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/thingalert_secondary"
        android:textStyle="bold"
        android:textSize="16sp" />

      <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/deviceNoteButton"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/edit_device_note"
        android:padding="7dp"
        app:srcCompat="@drawable/ic_edit"
        app:tint="@color/thingalert_secondary" />

      <TextView
        android:id="@+id/deviceStar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="4dp"
        android:text="☆"
        android:textColor="@color/thingalert_primary"
        android:textSize="22sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/deviceMeta"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:textColor="@color/thingalert_on_background" />

    <TextView
      android:id="@+id/deviceRssi"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:textColor="@color/thingalert_primary" />
  </LinearLayout>
</com.google.android.material.card.MaterialCardView>
