<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/drawerLayout"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/thingalert_background">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
      android:id="@+id/toolbar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/thingalert_surface"
      android:elevation="0dp"
      android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
      android:title="@string/app_name_header"
      app:navigationIconTint="@color/thingalert_secondary"
      app:subtitleTextColor="@color/thingalert_secondary"
      app:titleTextColor="@color/thingalert_on_surface" />

    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="@color/thingalert_stroke_soft" />

    <HorizontalScrollView
      android:id="@+id/deviceGroupScroll"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/thingalert_surface"
      android:fillViewport="true"
      android:scrollbars="none">

      <LinearLayout
        android:id="@+id/deviceGroupRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
          android:id="@+id/groupAllButton"
          style="@style/ThingAlertFilterPill"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginEnd="8dp"
          android:text="@string/device_group_all" />

        <com.google.android.material.button.MaterialButton
          android:id="@+id/groupStarredButton"
          style="@style/ThingAlertFilterPill"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginEnd="8dp"
          android:text="@string/device_group_starred" />

        <com.google.android.material.button.MaterialButton
          android:id="@+id/groupActiveButton"
          style="@style/ThingAlertFilterPill"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginEnd="8dp"
          android:text="@string/device_group_active" />

        <com.google.android.material.button.MaterialButton
          android:id="@+id/groupAlertsButton"
          style="@style/ThingAlertFilterPill"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/device_group_alerts" />
      </LinearLayout>
    </HorizontalScrollView>

    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="@color/thingalert_stroke_soft" />

    <FrameLayout
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1">

      <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/deviceList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="24dp" />

      <TextView
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/panel_surface_subtle"
        android:gravity="center"
        android:padding="20dp"
        android:text="@string/no_devices"
        android:textColor="@color/thingalert_on_background"
        android:visibility="gone" />
    </FrameLayout>
  </LinearLayout>

  <ScrollView
    android:id="@+id/filterDrawer"
    android:layout_width="320dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="@color/thingalert_surface"
    android:fillViewport="true">

    <LinearLayout
      android:id="@+id/filterDrawerContent"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:paddingStart="16dp"
      android:paddingTop="20dp"
      android:paddingEnd="16dp"
      android:paddingBottom="24dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filters_panel_title"
        android:textColor="@color/thingalert_secondary"
        android:textSize="20sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/scanStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/scan_inactive"
        android:textColor="@color/thingalert_secondary"
        android:textStyle="bold" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/filters_panel_subtitle"
        android:textColor="@color/thingalert_on_background" />

      <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/thingalert_stroke_soft" />

      <TextView
        android:id="@+id/permissionHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/permissions_required"
        android:textColor="@color/thingalert_on_background"
        android:visibility="gone" />

      <com.google.android.material.button.MaterialButton
        android:id="@+id/permissionActionButton"
        style="@style/ThingAlertSecondaryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/grant_access"
        android:visibility="gone" />

      <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/filterInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/filter_hint"
          android:textColor="@color/thingalert_on_surface"
          android:textColorHint="@color/thingalert_secondary" />
      </com.google.android.material.textfield.TextInputLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/sort_label"
          android:textColor="@color/thingalert_on_background" />

        <Spinner
          android:id="@+id/sortSpinner"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="8dp"
          android:layout_weight="1" />
      </LinearLayout>

      <CheckBox
        android:id="@+id/liveOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/live_only"
        android:textColor="@color/thingalert_on_background" />

      <CheckBox
        android:id="@+id/unknownOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/unknown_only"
        android:textColor="@color/thingalert_on_background" />

      <CheckBox
        android:id="@+id/starredOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/starred_only"
        android:textColor="@color/thingalert_on_background" />
    </LinearLayout>
  </ScrollView>

</androidx.drawerlayout.widget.DrawerLayout>
