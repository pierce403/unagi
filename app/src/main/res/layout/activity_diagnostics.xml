<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/thingalert_background"
  android:orientation="vertical">

  <com.google.android.material.appbar.MaterialToolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/thingalert_surface"
    android:elevation="0dp"
    android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
    app:navigationIconTint="@color/thingalert_secondary"
    app:titleTextColor="@color/thingalert_on_surface"
    android:title="@string/diagnostics" />

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="@color/thingalert_stroke_soft" />

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/thingalert_background">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/compatibilityModeSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:text="@string/compatibility_mode"
        android:textColor="@color/thingalert_on_surface" />

      <TextView
        android:id="@+id/compatibilityModeHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:text="@string/compatibility_mode_detail"
        android:textColor="@color/thingalert_on_background" />

      <TextView
        android:id="@+id/diagnosticsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/panel_surface_subtle"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:textColor="@color/thingalert_on_surface"
        android:textIsSelectable="true" />
    </LinearLayout>
  </ScrollView>
</LinearLayout>
