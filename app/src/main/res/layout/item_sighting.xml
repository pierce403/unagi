<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginBottom="10dp"
  app:cardBackgroundColor="@color/thingalert_surface"
  app:cardCornerRadius="18dp"
  app:cardElevation="0dp"
  app:strokeColor="@color/thingalert_stroke_soft"
  app:strokeWidth="1dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
      android:id="@+id/sightingTimestamp"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textColor="@color/thingalert_secondary"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/sightingRssi"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:textColor="@color/thingalert_primary" />

    <TextView
      android:id="@+id/sightingMeta"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:textColor="@color/thingalert_on_background" />
  </LinearLayout>
</com.google.android.material.card.MaterialCardView>
